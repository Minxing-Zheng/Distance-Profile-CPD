# Define parameter ranges
perturbation_levels <- seq(0, 1, by = 0.1)  # Range: 0 to 1, step 0.1
deltas <- seq(0, 1, by = 0.5)              # Range: 0, 0.5, 1
perturbate_types <- c("outlier", "exp")    # Two types
monte_carlos <- 1:100                      # Range: 1 to 100
feature_outlier_perturbates <- c(0.1, 0.2, 0.3)  # Specific values
# Generate all combinations of parameters
param_grid <- expand.grid(
perturbation_level = perturbation_levels,
delta = deltas,
perturbate_type = perturbate_types,
monte_carlo = monte_carlos,
feature_outlier_perturbate = feature_outlier_perturbates,
stringsAsFactors = FALSE
)
# Assign seeds using the 100000 * monte_carlo + combination formula
param_grid$seed <- apply(param_grid, 1, function(row) {
# Convert necessary elements to numeric
monte_carlo <- as.numeric(row["monte_carlo"])
perturbation_level <- as.numeric(row["perturbation_level"])
delta <- as.numeric(row["delta"])
feature_outlier_perturbate <- as.numeric(row["feature_outlier_perturbate"])
# Encode perturbate_type as a numeric value
perturbate_type <- ifelse(row["perturbate_type"] == "outlier", 1, 2)
# Compute the "something" value
something <- round(perturbation_level * 1000) +
round(delta * 100) * 10 +
perturbate_type * 100 +
round(feature_outlier_perturbate * 10)
# Compute the seed
seed <- 100000 * monte_carlo + something
return(seed)
})
