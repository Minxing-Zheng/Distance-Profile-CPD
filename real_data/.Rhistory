depth_pval = depth_loc,
depth_dF_pval = depth_dF_loc,
depth_AD_pval = depth_AD_loc,
depth_W_pval = depth_W_loc,
graph_pval = graph_loc,
ecp_pval = ecp_loc,
mmd_pval = mmd_pval,
stringsAsFactors = FALSE
)
}
result_list <- lapply(0:3, run_one_example_null,num_permut_depth = 10,
B_graph = 500,
R_ecp = 500,
n_perm_mmd = 200)
depth_W_loc  <- depth_all_pval[3]
run_one_example_null <- function(i,
base_dir = "mix_human_machine_text/embeddings_after_cp_max200",
num_permut_depth = 100,
B_graph = 1000,
R_ecp = 1000,
n_perm_mmd = 300) {
stem <- sprintf("ex_%04d", i)
rdata_path <- file.path(base_dir, paste0(stem, ".RData"))
json_path  <- file.path(base_dir, paste0(stem, ".json"))
if (!file.exists(rdata_path) || !file.exists(json_path)) {
message("[skip missing] ", stem)
return(NULL)
}
# ---- load data ----
Data <- tryCatch({
get(load(rdata_path))
}, error = function(e) {
message("[skip load RData fail] ", stem, " : ", e$message)
return(NULL)
})
if (is.null(Data)) return(NULL)
meta <- tryCatch({
fromJSON(json_path)
}, error = function(e) {
message("[skip load json fail] ", stem, " : ", e$message)
return(NULL)
})
if (is.null(meta)) return(NULL)
true_cp <- meta$cp_word_original
X <- as.matrix(Data)
n <- nrow(X)
if (is.null(true_cp) || n <= 2) {
message("[skip invalid] ", stem)
return(NULL)
}
# ---- cosine distance matrix ----
norms <- sqrt(rowSums(X^2))
Xn <- X / pmax(norms, .Machine$double.eps)
cos_sim <- Xn %*% t(Xn)
cos_dist <- 1 - cos_sim
diag(cos_dist) <- 0
# ----------------------------
# depth CPD
# ----------------------------
depth_loc <- tryCatch({
res1 <- depth_CPD_cpp_parallel(cos_dist, c = 0.1, num_permut = num_permut_depth)
as.numeric(res1$p_val)
}, error = function(e) NA_real_)
depth_all_pval <- tryCatch({
obs <- depth_one_perm_cpp(cos_dist, c = 0.1, do_permute = FALSE)
perm_res <- mclapply(
X = seq_len(num_permut_depth),
FUN = function(b) depth_one_perm_cpp(cos_dist, c = 0.1, do_permute = TRUE),
mc.cores = n_cores
)
perm_mat <- do.call(rbind, lapply(perm_res, function(x) {
c(
stat_dF = unname(x["stat_dF"]),
stat_AD = unname(x["stat_AD"]),
stat_W  = unname(x["stat_W"]),
loc_dF  = unname(x["loc_dF"]),
loc_AD  = unname(x["loc_AD"]),
loc_W   = unname(x["loc_W"])
)
}))
colnames(perm_mat) <- c("stat_dF", "stat_AD", "stat_W", "loc_dF", "loc_AD", "loc_W")
c(
dF = (1 + sum(perm_mat[, "stat_dF"] >= unname(obs["stat_dF"]), na.rm = TRUE)) / (num_permut_depth + 1),
AD = (1 + sum(perm_mat[, "stat_AD"] >= unname(obs["stat_AD"]), na.rm = TRUE)) / (num_permut_depth + 1),
W  = (1 + sum(perm_mat[, "stat_W"]  >= unname(obs["stat_W"]),  na.rm = TRUE)) / (num_permut_depth + 1)
)
}, error = function(e) c(NA_real_, NA_real_, NA_real_))
depth_dF_loc <- depth_all_pval[1]
depth_AD_loc <- depth_all_pval[2]
depth_W_loc  <- depth_all_pval[3]
# ----------------------------
# graph CPD
# ----------------------------
graph_loc <- tryCatch({
E1 <- mstree(as.dist(cos_dist), ngmax = 5)
result_graph <- gseg1(nrow(cos_dist), E1,
statistics = "g",
B = B_graph,
pval.perm = TRUE)
as.numeric(result_graph$pval.perm$generalized$pval)
}, error = function(e) NA_real_)
# ----------------------------
# energy CPD
# ----------------------------
ecp_loc <- tryCatch({
result_ecp <- e.divisive_distmat(
D = cos_dist,
sig.lvl = 0.05,
R = R_ecp,
min.size = 50,
alpha = 1
)
as.numeric(result_ecp$p.values[1])
}, error = function(e) NA_real_)
# ----------------------------
# MMD
# ----------------------------
run_one_mmd <- function(j, cos_dist) {
if (j != 0) {
ind <- sample.int(nrow(cos_dist))
D <- cos_dist[ind, ind]
} else {
D <- cos_dist
}
result_mmd <- MMD_test(D)
loc <- which.max(result_mmd)
ob_stat <- result_mmd[loc]
c(loc = loc, ob_stat = ob_stat)
}
mmd_res <- tryCatch({
n_cores <- max(1, detectCores() - 1)
result_list <- mclapply(
X = 0:n_perm_mmd,
FUN = run_one_mmd,
cos_dist = cos_dist,
mc.cores = n_cores
)
do.call(rbind, result_list)
}, error = function(e) NULL)
mmd_loc <- if (!is.null(mmd_res)) as.numeric(mmd_res[1, "loc"]) else NA_real_
mmd_stat <- if (!is.null(mmd_res)) as.numeric(mmd_res[1, "ob_stat"]) else NA_real_
mmd_pval <- if (!is.null(mmd_res)) {
perm_stats <- as.numeric(mmd_res[-1, "ob_stat"])
(1 + sum(perm_stats >= mmd_stat, na.rm = TRUE)) / (length(perm_stats) + 1)
} else {
NA_real_
}
# ----------------------------
# collect
# ----------------------------
data.frame(
idx = i,
file = stem,
n = n,
# true_cp = as.numeric(true_cp),
depth_pval = depth_loc,
depth_dF_pval = depth_dF_loc,
depth_AD_pval = depth_AD_loc,
depth_W_pval = depth_W_loc,
graph_pval = graph_loc,
ecp_pval = ecp_loc,
mmd_pval = mmd_pval,
stringsAsFactors = FALSE
)
}
result_list <- lapply(0:3, run_one_example_null,num_permut_depth = 10,
B_graph = 500,
R_ecp = 500,
n_perm_mmd = 200)
result_list <- lapply(0:10, run_one_example_null,num_permut_depth = 200,
B_graph = 500,
R_ecp = 500,
n_perm_mmd = 200)
result_df <- do.call(rbind, Filter(Negate(is.null), result_list))
result_df
perm_mat[, "stat_dF"]
perm_mat
perm_mat$loc_dF
perm_mat[,loc_dF]
perm_mat[:,"loc_dF"]
perm_mat[,"loc_dF"]
perm_mat[,"loc_dF"]
perm_mat
obs
obs <- depth_one_perm_cpp(cos_dist, c = 0.1, do_permute = FALSE)
obs
obs[4:]
obs[4:6]
res1<-depth_one_perm_single_cpp(cos_dist, c = 0.1, do_permute = FALSE)
res1
res1$loc
res1[1]
run_one_example <- function(i,
base_dir = "mix_human_machine_text/embeddings_word_boundary_300words",
num_permut_depth = 1,
B_graph = 1000,
R_ecp = 1000,
n_perm_mmd = 300) {
stem <- sprintf("ex_%04d", i)
rdata_path <- file.path(base_dir, paste0(stem, ".RData"))
json_path  <- file.path(base_dir, paste0(stem, ".json"))
if (!file.exists(rdata_path) || !file.exists(json_path)) {
message("[skip missing] ", stem)
return(NULL)
}
# ---- load data ----
Data <- tryCatch({
get(load(rdata_path))
}, error = function(e) {
message("[skip load RData fail] ", stem, " : ", e$message)
return(NULL)
})
if (is.null(Data)) return(NULL)
meta <- tryCatch({
fromJSON(json_path)
}, error = function(e) {
message("[skip load json fail] ", stem, " : ", e$message)
return(NULL)
})
if (is.null(meta)) return(NULL)
true_cp <- meta$cp_word
X <- as.matrix(Data)
n <- nrow(X)
if (is.null(true_cp) || n <= 2) {
message("[skip invalid] ", stem)
return(NULL)
}
# ---- cosine distance matrix ----
norms <- sqrt(rowSums(X^2))
Xn <- X / pmax(norms, .Machine$double.eps)
cos_sim <- Xn %*% t(Xn)
cos_dist <- 1 - cos_sim
diag(cos_dist) <- 0
# ----------------------------
# depth CPD
# ----------------------------
depth_loc <- tryCatch({
res1<-depth_one_perm_single_cpp(cos_dist, c = 0.1, do_permute = FALSE)
# res1 <- depth_CPD_cpp_parallel(cos_dist, c = 0.1, num_permut = num_permut_depth)
as.numeric(res1[1])
}, error = function(e) NA_real_)
depth_all_loc <- tryCatch({
res_all <- depth_one_perm_cpp(cos_dist, c = 0.1, do_permute = FALSE)
loc <- as.numeric(res_all$loc)
if (length(loc) < 3) c(NA_real_, NA_real_, NA_real_) else loc[1:3]
}, error = function(e) c(NA_real_, NA_real_, NA_real_))
depth_dF_loc <- depth_all_loc[1]
depth_AD_loc <- depth_all_loc[2]
depth_W_loc  <- depth_all_loc[3]
# ----------------------------
# graph CPD
# ----------------------------
graph_loc <- tryCatch({
E1 <- mstree(as.dist(cos_dist), ngmax = 5)
result_graph <- gseg1(nrow(cos_dist), E1,
statistics = "g",
B = B_graph,
pval.perm = TRUE)
as.numeric(result_graph$scanZ$generalized$tauhat)
}, error = function(e) NA_real_)
# ----------------------------
# energy CPD
# ----------------------------
ecp_loc <- tryCatch({
result_ecp <- e.divisive_distmat(
D = cos_dist,
sig.lvl = 0.05,
R = R_ecp,
k = 1,
min.size = 50,
alpha = 1
)
est <- result_ecp$estimates
if (length(est) >= 3) {
as.numeric(est[2])
} else {
NA_real_
}
}, error = function(e) NA_real_)
# ----------------------------
# MMD
# ----------------------------
run_one_mmd <- function(j, cos_dist) {
if (j != 0) {
ind <- sample(nrow(cos_dist))
D <- cos_dist[ind, ind]
} else {
D <- cos_dist
}
result_mmd <- MMD_test(D)
loc <- which.max(result_mmd)
ob_stat <- result_mmd[loc]
c(loc = loc, ob_stat = ob_stat)
}
mmd_res <- tryCatch({
n_cores <- max(1, detectCores() - 1)
result_list <- mclapply(
X = 0:n_perm_mmd,
FUN = run_one_mmd,
cos_dist = cos_dist,
mc.cores = n_cores
)
do.call(rbind, result_list)
}, error = function(e) NULL)
mmd_loc <- if (!is.null(mmd_res)) as.numeric(mmd_res[1, "loc"]) else NA_real_
mmd_stat <- if (!is.null(mmd_res)) as.numeric(mmd_res[1, "ob_stat"]) else NA_real_
# ----------------------------
# collect
# ----------------------------
data.frame(
idx = i,
file = stem,
n = n,
true_cp = as.numeric(true_cp),
depth_loc = depth_loc,
depth_dF_loc = depth_dF_loc,
depth_AD_loc = depth_AD_loc,
depth_W_loc = depth_W_loc,
graph_loc = graph_loc,
ecp_loc = ecp_loc,
mmd_loc = mmd_loc,
stringsAsFactors = FALSE
)
}
# ----------------------------
# main loop over first 100
# ----------------------------
result_list <- lapply(0:300, run_one_example,num_permut_depth = 1,
B_graph = 300,
R_ecp = 300,
n_perm_mmd = 1)
mae_summary
result_df <- do.call(rbind, Filter(Negate(is.null), result_list))
result_df
