loc <- res_all$loc
loc
depth_all_loc <- tryCatch({
res_all = depth_CPDcpp_ALL(cos_dist,num_permut = 0) # dF, AD, W
loc <- res_all$loc
if (length(loc) < 3) c(NA_real_, NA_real_, NA_real_) else loc[1:3]
}, error = function(e) c(NA_real_, NA_real_, NA_real_))
